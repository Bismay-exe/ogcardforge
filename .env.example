# GitHub Personal Access Token (classic or fine-grained)
# Required for production (5000 req/hr). Without it the API falls back to 60 req/hr unauthenticated
# and quickly hits rate limits under any meaningful traffic.
GITHUB_TOKEN=

# Optional: Vercel KV connection string. If unset, an in-memory cache is used.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
